{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sboxcool.com/schemas/network-storage/source-authoring.schema.json",
  "title": "Network Storage Source Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [ "sourceVersion", "kind", "id", "definition" ],
  "properties": {
    "sourceVersion": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "enum": [ "collection", "endpoint", "workflow", "test", "library" ]
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "notes": { "type": "string" },
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "definition": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": [ "id", "type" ],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "transform",
            "condition",
            "lookup",
            "filter",
            "workflow",
            "block",
            "while",
            "until",
            "foreach",
            "call",
            "return"
          ]
        },
        "when": { "type": [ "object", "string" ] },
        "body": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  }
}
